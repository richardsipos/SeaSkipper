rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isBoolMap(value) {
      return value is map
        && value.keys().size() <= 600
        && value.values().hasOnly([true, false]);
    }

    function isIntMap(value) {
      return value is map
        && value.keys().size() <= 600
        && value.values().hasOnly([0, 1, 2]);
    }

    function isProgressDoc(data) {
      return data.keys().hasOnly([
          'schemaVersion',
          'goodIds',
          'badIds',
          'answersById',
          'submittedAnswerIndexById',
          'updatedAt'
        ])
        && (('schemaVersion' in data) ? data.schemaVersion is int : true)
        && (('goodIds' in data) ? (data.goodIds is list && data.goodIds.size() <= 600) : true)
        && (('badIds' in data) ? (data.badIds is list && data.badIds.size() <= 600) : true)
        && (('answersById' in data) ? isBoolMap(data.answersById) : true)
        && (('submittedAnswerIndexById' in data) ? isIntMap(data.submittedAnswerIndexById) : true)
        && (('updatedAt' in data) ? data.updatedAt is timestamp : true);
    }

    function isUserDoc(data) {
      return data.keys().hasOnly([
          'schemaVersion',
          'createdAt',
          'updatedAt'
        ])
        && (('schemaVersion' in data) ? data.schemaVersion is int : true)
        && (('createdAt' in data) ? data.createdAt is timestamp : true)
        && (('updatedAt' in data) ? data.updatedAt is timestamp : true);
    }

    // Users collection: one document per Firebase Auth UID.
    match /users/{userId} {
      allow read, create, update: if isOwner(userId) && isUserDoc(request.resource.data);
      allow delete: if false;

      // Progress subcollection:
      // - users/{uid}/progress/main
      match /progress/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && docId == 'main'
          && isProgressDoc(request.resource.data);
        allow delete: if false;
      }
    }
  }
}
